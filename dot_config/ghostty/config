theme = tokyonight

# Disable ligatures
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# Always open new windows in $HOME instead of inheriting the parent's CWD
working-directory = home
window-inherit-working-directory = false

# Override Ghostty's default "performable:copy_to_clipboard" on Cmd-C, which
# passes the key through when there's no selection (leaking a stray "c" while
# herdr owns the selection). This always consumes Cmd-C instead.
keybind = super+c=copy_to_clipboard

