[color]
    diff = auto
    status = auto
    branch = auto

[alias]
    st = status
    ci = commit
    br = branch
    co = checkout

    c = commit --verbose
    ca = commit --verbose --all
    l = log --graph --pretty=format:'%C(dim)%h - %cs (%cr) -%Creset %s %C(dim)-%Creset %C(cyan)%an%Creset%C(yellow)%d%Creset' --abbrev-commit --abbrev=7
    lg = l

    # Delete all local branches whose remote branch has been deleted
    trim = !git fetch --prune && git branch -vv | grep \": gone]\" | awk \"{print \\$1}\" | xargs git branch -D

[push]
	default = simple

[pull]
	rebase = true

[init]
	defaultBranch = main

[rebase]
	updateRefs = true
	autoSquash = true
