#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["typer"]
# ///
"""cab: claude agent box, a per-project Claude Code container.

Builds the image on first use, then keeps one container per project
directory (named after the basename of the CWD).
"""

import hashlib
import os
import subprocess

import typer

IMAGE = "cab"

DOCKERFILE = """\
FROM node:22

RUN npm install -g @anthropic-ai/claude-code

# Pre-create the config dir owned by node so a fresh named volume
# mounted here inherits node ownership instead of defaulting to root.
RUN mkdir -p /home/node/.claude && chown node:node /home/node/.claude

USER node
WORKDIR /workspace

# Keep the container alive as a persistent box; cab launches claude via exec.
CMD ["sleep", "infinity"]
"""


def run(*args: str, **kwargs) -> subprocess.CompletedProcess:
    return subprocess.run(args, check=True, **kwargs)


def quiet_ok(*args: str) -> bool:
    return subprocess.run(
        args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    ).returncode == 0


def main(
    label: str = typer.Argument(
        None, help="Container label; defaults to the CWD basename."
    ),
    force_build: bool = typer.Option(
        False, "--build", help="Rebuild the image and recreate the container."
    ),
    stop: bool = typer.Option(
        False, "--stop", help="Stop the container and exit."
    ),
    kill: bool = typer.Option(
        False, "--kill", help="Remove the container and exit."
    ),
    shell: bool = typer.Option(
        False, "--shell", help="Exec a shell instead of the Claude agents UI."
    ),
) -> None:
    """cab: claude agent box, a per-project Claude Code container."""
    if stop and kill:
        raise typer.BadParameter("--stop and --kill are mutually exclusive.")

    cwd = os.getcwd()

    # Container name: "cab-<label>-<hash>", where <label> is the given label
    # or the CWD basename, and <hash> keeps it unique per directory so two
    # projects sharing a basename don't collide.
    label = label or os.path.basename(cwd)
    digest = hashlib.sha1(cwd.encode()).hexdigest()[:8]
    name = f"{IMAGE}-{label}-{digest}"

    exists = quiet_ok("docker", "container", "inspect", name)

    # --stop and --kill are terminal actions: act on the container, then exit.
    if stop:
        if exists:
            run("docker", "stop", name, stdout=subprocess.DEVNULL)
        raise typer.Exit()
    if kill:
        if exists:
            run("docker", "rm", "-f", name, stdout=subprocess.DEVNULL)
        raise typer.Exit()

    # Build the image if forced, or if the daemon does not already have it.
    if force_build or not quiet_ok("docker", "image", "inspect", IMAGE):
        run("docker", "build", "-t", IMAGE, "-", input=DOCKERFILE, text=True)

    # A rebuilt image leaves the old container running stale code, so drop it
    # and let the block below recreate it on the fresh image.
    if force_build and exists:
        run("docker", "rm", "-f", name, stdout=subprocess.DEVNULL)
        exists = False

    # Ensure the project container is running, creating it on first use.
    if not exists:
        run(
            "docker", "run", "-d", "--name", name,
            "-v", f"{name}-dot_claude:/home/node/.claude",
            "-v", f"{os.path.expanduser('~')}/.ssh/id_ed25519_claude:/home/node/.ssh/id_ed25519:ro",
            "-v", f"{cwd}:/workspace",
            IMAGE,
            stdout=subprocess.DEVNULL,
        )
    else:
        running = subprocess.run(
            ["docker", "inspect", "-f", "{{.State.Running}}", name],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
        if running != "true":
            run("docker", "start", name, stdout=subprocess.DEVNULL)

    # Drop into the container. execvp replaces this process with docker so no
    # wrapper lingers as its parent.
    target = ["bash"] if shell else ["claude", "agents"]
    os.execvp("docker", ["docker", "exec", "-it", name, *target])


if __name__ == "__main__":
    typer.run(main)
