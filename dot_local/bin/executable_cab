#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["typer", "rich"]
# ///
"""cab: claude agent box, a named Claude Code container.

Builds the image on first use, then keeps one container per name.
"""

import os
import shutil
import subprocess
from pathlib import Path

import click
import typer
from rich.console import Console
from rich.table import Table
from typer.core import TyperGroup

console = Console()

IMAGE = "cab"
PREFIX = "cab"
# Docker object label stamped on every cab container so `list` can find
# them. Spelled out in full to avoid colliding with unrelated labels.
DOCKER_LABEL = "claude_agents_box"

# Per-name home directories live here on the host, bind-mounted at
# /home/node. New homes are seeded once from SKEL_DIR.
STATE_DIR = Path.home() / ".local/state/cab/home_dir"
SKEL_DIR = Path.home() / ".config/cab/skel"

# Socket for the in-container ssh-agent. Kept off the /home/node bind
# mount: unix sockets on the virtiofs mount are unreliable.
SSH_AGENT_SOCK = "/tmp/cab-ssh-agent.sock"

DOCKERFILE = """\
FROM node:22

RUN npm install -g @anthropic-ai/claude-code

# /home/node is a per-name host directory bind-mounted at runtime, so
# anything seeded into it here would be shadowed. Common home files come
# from the host skel directory instead.

# Pre-create the workdir owned by node. Otherwise docker auto-creates
# /workspace from WORKDIR owned by root, and the agent (running as
# node) cannot write to it without escalating to root.
RUN mkdir -p /workspace && chown node:node /workspace

USER node
WORKDIR /workspace

# Keep the container alive as a persistent box; cab launches claude via exec.
CMD ["sleep", "infinity"]
"""


class DefaultCommandGroup(TyperGroup):
    """When the first argument is not a known subcommand, treat it as a
    NAME for the default `agents` command, so `cab myproject` works."""

    def resolve_command(self, ctx, args):
        try:
            return super().resolve_command(ctx, args)
        except click.UsageError:
            return super().resolve_command(ctx, ["agents", *args])


app = typer.Typer(cls=DefaultCommandGroup, add_completion=False)


def run(*args: str, **kwargs) -> subprocess.CompletedProcess:
    return subprocess.run(args, check=True, **kwargs)


def quiet_ok(*args: str) -> bool:
    return subprocess.run(
        args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    ).returncode == 0


def require_docker() -> None:
    """Exit cleanly if the docker CLI is missing or its daemon is down,
    rather than letting a raw traceback reach the user."""
    try:
        ok = quiet_ok("docker", "info")
    except FileNotFoundError:
        ok = False
    if not ok:
        typer.echo("Docker is not available. Is the daemon running?", err=True)
        raise typer.Exit(1)


def container_name(name: str) -> str:
    return f"{PREFIX}-{name}"


def home_dir(name: str) -> Path:
    return STATE_DIR / name


def ensure_home(name: str) -> Path:
    """Return the host home directory for NAME, creating it on first use.
    A fresh home is seeded from SKEL_DIR so common non-secret config (e.g.
    .gitconfig, .ssh/known_hosts) is present without per-name setup."""
    home = home_dir(name)
    if not home.exists():
        if SKEL_DIR.is_dir():
            shutil.copytree(SKEL_DIR, home)
        else:
            home.mkdir(parents=True)
    return home


def ensure_image(force_build: bool) -> None:
    if force_build or not quiet_ok("docker", "image", "inspect", IMAGE):
        run("docker", "build", "-t", IMAGE, "-", input=DOCKERFILE, text=True)


def is_running(container: str) -> bool:
    return subprocess.run(
        ["docker", "inspect", "-f", "{{.State.Running}}", container],
        capture_output=True, text=True, check=True,
    ).stdout.strip() == "true"


def ensure_running(name: str) -> str:
    """Create the container on first use, or start it if stopped. Returns
    the docker container name."""
    container = container_name(name)
    if not quiet_ok("docker", "container", "inspect", container):
        home = ensure_home(name)
        run(
            "docker", "run", "-d", "--name", container,
            "--label", f"{DOCKER_LABEL}=true",
            "-v", f"{home}:/home/node",
            IMAGE, stdout=subprocess.DEVNULL,
        )
    elif not is_running(container):
        run("docker", "start", container, stdout=subprocess.DEVNULL)
    return container


def seed_ssh_agent(container: str, key_path: str) -> None:
    """Load the host private key into an ssh-agent running inside the
    container. The key is piped over docker exec stdin, so it lives only
    in the agent's memory and never touches the container filesystem.
    Idempotent: the agent is started only if not already reachable, and
    re-seeding survives a container restart that killed the old agent."""
    script = f"""
        sock={SSH_AGENT_SOCK}
        SSH_AUTH_SOCK=$sock ssh-add -l >/dev/null 2>&1
        if [ $? -eq 2 ]; then
            rm -f "$sock"
            eval "$(ssh-agent -a "$sock")" >/dev/null
        fi
        SSH_AUTH_SOCK=$sock ssh-add - >/dev/null 2>&1
    """
    with open(key_path, "rb") as key:
        result = subprocess.run(
            ["docker", "exec", "-i", container, "sh", "-c", script], stdin=key
        )
    if result.returncode != 0:
        console.print(
            f"Could not load SSH key [cyan]{key_path}[/] into the agent. "
            "Passphrase-protected keys are not supported.",
            style="yellow",
        )


def enter(name: str, target: list[str], ssh_key: str | None) -> None:
    """Ensure the image and container exist, then exec into the container.
    execvp replaces this process with docker so no wrapper lingers."""
    ensure_image(force_build=False)
    container = ensure_running(name)
    env: list[str] = []
    if ssh_key:
        seed_ssh_agent(container, ssh_key)
        env = ["-e", f"SSH_AUTH_SOCK={SSH_AGENT_SOCK}"]
    os.execvp("docker", ["docker", "exec", "-it", *env, container, *target])


@app.callback(invoke_without_command=True)
def cli(
    ctx: typer.Context,
    ssh_key: str = typer.Option(
        None, "--ssh-key", envvar="CAB_SSH_KEY", metavar="PATH",
        help="Private key to load into an in-container ssh-agent for git "
             "over SSH. The key is never written to the container's "
             "filesystem.",
    ),
) -> None:
    """cab: claude agent box, a named Claude Code container.

    Run `cab NAME` to launch the Claude agents UI in a container named
    NAME, building the image and creating the container on first use.
    `cab NAME` is shorthand for `cab agents NAME`. The other subcommands
    manage existing containers.

    Each container has a host home directory at
    ~/.local/state/cab/home_dir/NAME/ bind-mounted at /home/node, so
    Claude config and history persist across restarts. A fresh home is
    seeded from ~/.config/cab/skel/ (mirroring /home/node), the place to
    put common non-secret files such as .gitconfig and .ssh/known_hosts.
    `cab kill --purge` removes a container's home directory.

    With --ssh-key (or $CAB_SSH_KEY), the key is loaded into an
    ssh-agent inside the container for git over SSH, without ever being
    written to the container's filesystem.
    """
    if ctx.invoked_subcommand is None:
        console.print("Specify a proejct name, for example [bold]cab myproject[/].")
        console.print("[dim]Run [bold]cab --help[/] for all commands.[/]")
        raise typer.Exit(1)
    require_docker()
    if ssh_key is not None:
        ssh_key = os.path.expanduser(ssh_key)
        if not os.path.isfile(ssh_key):
            console.print(f"SSH key not found: [cyan]{ssh_key}[/]", style="red")
            raise typer.Exit(1)
    ctx.obj = ssh_key


@app.command()
def agents(
    ctx: typer.Context,
    name: str = typer.Argument(..., help="Container name."),
) -> None:
    """Launch the Claude agents UI in the container (the default action)."""
    enter(name, ["claude", "agents"], ctx.obj)


@app.command()
def shell(
    ctx: typer.Context,
    name: str = typer.Argument(..., help="Container name."),
) -> None:
    """Exec a shell in the container."""
    enter(name, ["bash"], ctx.obj)


@app.command()
def build() -> None:
    """Rebuild the image. Existing containers pick it up when recreated."""
    ensure_image(force_build=True)


@app.command()
def stop(
    name: str = typer.Argument(..., help="Container name."),
) -> None:
    """Stop the container."""
    container = container_name(name)
    if quiet_ok("docker", "container", "inspect", container):
        run("docker", "stop", container, stdout=subprocess.DEVNULL)
        console.print(f"Stopped [cyan]{container}[/].")
    else:
        console.print(f"No such container: [cyan]{container}[/]", style="dim")


@app.command()
def kill(
    name: str = typer.Argument(..., help="Container name."),
    purge: bool = typer.Option(
        False, "--purge",
        help="Also remove the host home directory holding the container's "
             "Claude config and home files.",
    ),
) -> None:
    """Remove the container. Its host home directory is left intact unless
    --purge."""
    container = container_name(name)
    home = home_dir(name)
    container_exists = quiet_ok("docker", "container", "inspect", container)
    home_exists = home.is_dir()
    if not container_exists and not home_exists:
        console.print(f"Nothing to remove for [cyan]{name}[/].", style="dim")
        return

    if container_exists:
        run("docker", "rm", "-f", container, stdout=subprocess.DEVNULL)
        console.print(f"Removed container [cyan]{container}[/].")

    # The home directory holds the saved Claude config, so it is kept
    # unless --purge.
    if home_exists and purge:
        shutil.rmtree(home)
        console.print(f"Removed home directory [cyan]{home}[/].")
    elif home_exists:
        console.print(f"[dim]Home directory [cyan]{home}[/] kept.[/]")


@app.command("list")
def list_() -> None:
    """List all cab containers and home directories, including orphans."""
    containers = subprocess.run(
        ["docker", "ps", "-a", "--filter", f"label={DOCKER_LABEL}",
         "--format", "{{.Names}}\t{{.State}}"],
        capture_output=True, text=True, check=True,
    ).stdout.splitlines()
    homes = (
        [p.name for p in STATE_DIR.iterdir() if p.is_dir()]
        if STATE_DIR.is_dir() else []
    )

    # Join containers and home directories by name so an orphaned home
    # (one with no container) shows up as its own row.
    rows: dict[str, dict] = {}
    for line in containers:
        cname, _, state = line.partition("\t")
        name = cname.removeprefix(f"{PREFIX}-")
        rows.setdefault(name, {}).update(container=cname, state=state)
    for name in homes:
        rows.setdefault(name, {})["home"] = True

    if not rows:
        console.print("No cab containers or home directories.", style="dim")
        return

    table = Table()
    table.add_column("Name")
    table.add_column("State")
    table.add_column("Home")
    for name in sorted(rows):
        row = rows[name]
        state = row.get("state", "—")
        orphan = "container" not in row
        table.add_row(
            name,
            f"[green]{state}[/]" if state == "running" else state,
            "yes" if row.get("home") else "—",
            style="yellow" if orphan else None,
        )
    console.print(table)


if __name__ == "__main__":
    app()
