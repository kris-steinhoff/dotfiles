#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["typer", "rich"]
# ///
"""cab: claude agent box, a per-project Claude Code container.

Builds the image on first use, then keeps one container per label.
With no label, the label is derived from the CWD so each project
directory gets its own container.
"""

import hashlib
import os
import subprocess

import typer
from rich.console import Console
from rich.prompt import Confirm
from rich.table import Table

console = Console()

IMAGE = "cab"
PREFIX = "cab"
# Docker object label stamped on every cab container so `list` can find
# them. Spelled out in full to avoid colliding with unrelated labels.
DOCKER_LABEL = "claude_agents_box"

DOCKERFILE = """\
FROM node:22

RUN npm install -g @anthropic-ai/claude-code

# Pre-create the config dir owned by node so a fresh named volume
# mounted here inherits node ownership instead of defaulting to root.
RUN mkdir -p /home/node/.claude && chown node:node /home/node/.claude

USER node
WORKDIR /workspace

# Keep the container alive as a persistent box; cab launches claude via exec.
CMD ["sleep", "infinity"]
"""

app = typer.Typer(
    help="cab: claude agent box, a per-project Claude Code container.",
    add_completion=False,
    no_args_is_help=False,
)


def run(*args: str, **kwargs) -> subprocess.CompletedProcess:
    return subprocess.run(args, check=True, **kwargs)


def quiet_ok(*args: str) -> bool:
    return subprocess.run(
        args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    ).returncode == 0


def require_docker() -> None:
    """Exit cleanly if the docker CLI is missing or its daemon is down,
    rather than letting a raw traceback reach the user."""
    try:
        ok = quiet_ok("docker", "info")
    except FileNotFoundError:
        ok = False
    if not ok:
        typer.echo("Docker is not available. Is the daemon running?", err=True)
        raise typer.Exit(1)


def resolve(label: str | None) -> str:
    """An explicit label is taken at face value. Without one, derive a
    per-directory label from the CWD basename plus a hash of its path,
    so two projects sharing a basename don't collide."""
    if label:
        return label
    cwd = os.getcwd()
    digest = hashlib.sha1(cwd.encode()).hexdigest()[:8]
    return f"{os.path.basename(cwd)}-{digest}"


def container_name(label: str) -> str:
    return f"{PREFIX}-{label}"


def volume_name(label: str) -> str:
    return f"{PREFIX}-{label}-claude"


def ensure_image(force_build: bool) -> None:
    if force_build or not quiet_ok("docker", "image", "inspect", IMAGE):
        run("docker", "build", "-t", IMAGE, "-", input=DOCKERFILE, text=True)


def is_running(name: str) -> bool:
    return subprocess.run(
        ["docker", "inspect", "-f", "{{.State.Running}}", name],
        capture_output=True, text=True, check=True,
    ).stdout.strip() == "true"


def workspace_of(name: str) -> str:
    """The host directory bind-mounted at /workspace, with $HOME shortened
    to ~. Returns '—' when there is no such mount."""
    src = subprocess.run(
        ["docker", "inspect", "-f",
         '{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}',
         name],
        capture_output=True, text=True, check=True,
    ).stdout.strip()
    home = os.path.expanduser("~")
    if src.startswith(home):
        src = "~" + src[len(home):]
    return src or "—"


def ensure_running(label: str) -> str:
    """Create the container on first use, or start it if stopped. Returns
    the container name."""
    name = container_name(label)
    if not quiet_ok("docker", "container", "inspect", name):
        # Create the volume explicitly so it carries DOCKER_LABEL; an
        # implicit `-v` volume would be unlabelled and invisible to `list`.
        run(
            "docker", "volume", "create", "--label", f"{DOCKER_LABEL}=true",
            volume_name(label), stdout=subprocess.DEVNULL,
        )
        run(
            "docker", "run", "-d", "--name", name,
            "--label", f"{DOCKER_LABEL}=true",
            "-v", f"{volume_name(label)}:/home/node/.claude",
            "-v", f"{os.path.expanduser('~')}/.ssh/id_ed25519_claude:/home/node/.ssh/id_ed25519:ro",
            "-v", f"{os.getcwd()}:/workspace",
            IMAGE,
            stdout=subprocess.DEVNULL,
        )
    elif not is_running(name):
        run("docker", "start", name, stdout=subprocess.DEVNULL)
    return name


def enter(label: str | None, target: list[str]) -> None:
    """Ensure the image and container exist, then exec into the container.
    execvp replaces this process with docker so no wrapper lingers."""
    ensure_image(force_build=False)
    name = ensure_running(resolve(label))
    os.execvp("docker", ["docker", "exec", "-it", name, *target])


@app.callback(invoke_without_command=True)
def default(ctx: typer.Context) -> None:
    """Bare `cab` launches the agents UI for the current directory."""
    require_docker()
    if ctx.invoked_subcommand is None:
        enter(None, ["claude", "agents"])


@app.command()
def agents(
    label: str = typer.Argument(None, help="Container label; defaults to one derived from the current directory.")
) -> None:
    """Launch the Claude agents UI in the container (the default action)."""
    enter(label, ["claude", "agents"])


@app.command()
def shell(
    label: str = typer.Argument(None, help="Container label; defaults to one derived from the current directory.")
) -> None:
    """Exec a shell in the container."""
    enter(label, ["bash"])


@app.command()
def build() -> None:
    """Rebuild the image. Existing containers pick it up when recreated."""
    ensure_image(force_build=True)


@app.command()
def stop(
    label: str = typer.Argument(None, help="Container label; defaults to one derived from the current directory.")
) -> None:
    """Stop the container."""
    name = container_name(resolve(label))
    if quiet_ok("docker", "container", "inspect", name):
        run("docker", "stop", name, stdout=subprocess.DEVNULL)
        console.print(f"Stopped [cyan]{name}[/].")
    else:
        console.print(f"No such container: [cyan]{name}[/]", style="dim")


@app.command()
def kill(
    label: str = typer.Argument(None, help="Container label; defaults to one derived from the current directory."),
    force: bool = typer.Option(
        False, "--force", "-f", help="Skip confirmation prompts.",
    ),
    purge: bool = typer.Option(
        False, "--purge",
        help="Also remove the named volume holding the container's Claude config.",
    ),
) -> None:
    """Remove the container. Its named volume is left intact unless --purge."""
    label = resolve(label)
    name = container_name(label)
    vol = volume_name(label)
    container_exists = quiet_ok("docker", "container", "inspect", name)
    volume_exists = quiet_ok("docker", "volume", "inspect", vol)
    if not container_exists and not volume_exists:
        console.print(f"Nothing to remove for label [cyan]{label}[/].", style="dim")
        return

    running = container_exists and is_running(name)
    if running and not force:
        if not Confirm.ask(
            f"Delete container [cyan]{name}[/]? "
            "[yellow]This ends any active session.[/]",
            default=True,
        ):
            raise typer.Abort()

    if container_exists:
        run("docker", "rm", "-f", name, stdout=subprocess.DEVNULL)
        console.print(f"  Removed container [cyan]{name}[/].")

    # The volume holds the saved Claude config, so it is kept by default.
    # --purge removes it outright; otherwise ask, unless --force.
    remove_volume = volume_exists and (
        purge or (not force and Confirm.ask(
            f"Delete volume [cyan]{vol}[/]? "
            "[yellow]This is the saved Claude config.[/]",
            default=False,
        ))
    )
    if remove_volume:
        run("docker", "volume", "rm", vol, stdout=subprocess.DEVNULL)
        console.print(f"  Removed volume [cyan]{vol}[/].")
    elif volume_exists:
        console.print(f"  [dim]Volume [cyan]{vol}[/] kept.[/]")


@app.command("list")
def list_() -> None:
    """List all cab containers and volumes, including orphans."""
    containers = subprocess.run(
        ["docker", "ps", "-a", "--filter", f"label={DOCKER_LABEL}",
         "--format", "{{.Names}}\t{{.State}}"],
        capture_output=True, text=True, check=True,
    ).stdout.splitlines()
    volumes = subprocess.run(
        ["docker", "volume", "ls", "--filter", f"label={DOCKER_LABEL}",
         "--format", "{{.Name}}"],
        capture_output=True, text=True, check=True,
    ).stdout.splitlines()

    # Join containers and volumes by label so an orphaned volume (one with
    # no container) shows up as its own row.
    rows: dict[str, dict] = {}
    for line in containers:
        name, _, state = line.partition("\t")
        label = name.removeprefix(f"{PREFIX}-")
        rows.setdefault(label, {}).update(container=name, state=state)
    for vname in volumes:
        label = vname.removeprefix(f"{PREFIX}-").removesuffix("-claude")
        rows.setdefault(label, {})["volume"] = True

    if not rows:
        console.print("No cab containers or volumes.", style="dim")
        return

    table = Table()
    table.add_column("Label")
    table.add_column("State")
    table.add_column("Volume")
    table.add_column("Workspace")
    for label in sorted(rows):
        row = rows[label]
        state = row.get("state", "—")
        workspace = workspace_of(row["container"]) if "container" in row else "—"
        orphan = "container" not in row
        table.add_row(
            label,
            f"[green]{state}[/]" if state == "running" else state,
            "yes" if row.get("volume") else "—",
            workspace,
            style="yellow" if orphan else None,
        )
    console.print(table)


if __name__ == "__main__":
    app()
