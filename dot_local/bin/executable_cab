#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["typer", "rich"]
# ///
"""cab: claude agent box, a named Claude Code container.

Builds the image on first use, then keeps one container per name.
"""

import os
import subprocess

import click
import typer
from rich.console import Console
from rich.prompt import Confirm
from rich.table import Table
from typer.core import TyperGroup

console = Console()

IMAGE = "cab"
PREFIX = "cab"
# Docker object label stamped on every cab container so `list` can find
# them. Spelled out in full to avoid colliding with unrelated labels.
DOCKER_LABEL = "claude_agents_box"

DOCKERFILE = """\
FROM node:22

RUN npm install -g @anthropic-ai/claude-code

# Pre-create the config dir owned by node so a fresh named volume
# mounted here inherits node ownership instead of defaulting to root.
RUN mkdir -p /home/node/.claude && chown node:node /home/node/.claude

# Pre-seed host keys so git over SSH to these hosts doesn't prompt.
RUN mkdir -p /home/node/.ssh \\
    && ssh-keyscan gitlab.com github.com >> /home/node/.ssh/known_hosts \\
    && chmod 700 /home/node/.ssh \\
    && chmod 600 /home/node/.ssh/known_hosts \\
    && chown -R node:node /home/node/.ssh

USER node
WORKDIR /workspace

# Keep the container alive as a persistent box; cab launches claude via exec.
CMD ["sleep", "infinity"]
"""


class DefaultCommandGroup(TyperGroup):
    """When the first argument is not a known subcommand, treat it as a
    NAME for the default `agents` command, so `cab myproject` works."""

    def resolve_command(self, ctx, args):
        try:
            return super().resolve_command(ctx, args)
        except click.UsageError:
            return super().resolve_command(ctx, ["agents", *args])


app = typer.Typer(cls=DefaultCommandGroup, add_completion=False)


def run(*args: str, **kwargs) -> subprocess.CompletedProcess:
    return subprocess.run(args, check=True, **kwargs)


def quiet_ok(*args: str) -> bool:
    return subprocess.run(
        args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    ).returncode == 0


def require_docker() -> None:
    """Exit cleanly if the docker CLI is missing or its daemon is down,
    rather than letting a raw traceback reach the user."""
    try:
        ok = quiet_ok("docker", "info")
    except FileNotFoundError:
        ok = False
    if not ok:
        typer.echo("Docker is not available. Is the daemon running?", err=True)
        raise typer.Exit(1)


def container_name(name: str) -> str:
    return f"{PREFIX}-{name}"


def volume_name(name: str) -> str:
    return f"{PREFIX}-{name}-claude"


def ensure_image(force_build: bool) -> None:
    if force_build or not quiet_ok("docker", "image", "inspect", IMAGE):
        run("docker", "build", "-t", IMAGE, "-", input=DOCKERFILE, text=True)


def is_running(container: str) -> bool:
    return subprocess.run(
        ["docker", "inspect", "-f", "{{.State.Running}}", container],
        capture_output=True, text=True, check=True,
    ).stdout.strip() == "true"


def check_mount(spec: str) -> None:
    """Validate a `src:dst[:opts]` bind mount. The host path is used
    verbatim, as docker does (no ~ expansion). A path-like source is
    checked to exist so a typo does not silently become an empty
    directory; a source with no slash is treated as a named volume."""
    src, sep, _ = spec.partition(":")
    if not sep:
        console.print(
            f"Invalid bind mount, expected src:dst: [cyan]{spec}[/]", style="red"
        )
        raise typer.Exit(1)
    if "/" in src and not os.path.exists(src):
        console.print(
            f"Bind mount source not found: [cyan]{src}[/]", style="red"
        )
        raise typer.Exit(1)


def collect_mounts(mount_flags: list[str]) -> list[str]:
    """Bind mounts from $CAB_BIND_MOUNTS (newline-delimited) followed by
    --mount flags, each validated and passed to docker verbatim."""
    env = os.environ.get("CAB_BIND_MOUNTS", "")
    specs = [line.strip() for line in env.splitlines() if line.strip()]
    specs += mount_flags
    for spec in specs:
        check_mount(spec)
    return specs


def ensure_running(name: str, mount_flags: list[str]) -> str:
    """Create the container on first use, or start it if stopped. Returns
    the docker container name."""
    container = container_name(name)
    if not quiet_ok("docker", "container", "inspect", container):
        mounts = collect_mounts(mount_flags)
        # Create the volume explicitly so it carries DOCKER_LABEL; an
        # implicit `-v` volume would be unlabelled and invisible to `list`.
        run(
            "docker", "volume", "create", "--label", f"{DOCKER_LABEL}=true",
            volume_name(name), stdout=subprocess.DEVNULL,
        )
        opts = [
            "docker", "run", "-d", "--name", container,
            "--label", f"{DOCKER_LABEL}=true",
            "-v", f"{volume_name(name)}:/home/node/.claude",
        ]
        for mount in mounts:
            opts += ["-v", mount]
        run(*opts, IMAGE, stdout=subprocess.DEVNULL)
    elif not is_running(container):
        run("docker", "start", container, stdout=subprocess.DEVNULL)
    return container


def enter(name: str, target: list[str], mount_flags: list[str]) -> None:
    """Ensure the image and container exist, then exec into the container.
    execvp replaces this process with docker so no wrapper lingers."""
    ensure_image(force_build=False)
    container = ensure_running(name, mount_flags)
    os.execvp("docker", ["docker", "exec", "-it", container, *target])


@app.callback(invoke_without_command=True)
def cli(
    ctx: typer.Context,
    mount: list[str] = typer.Option(
        None, "--mount", "-m", metavar="SRC:DST[:OPTS]",
        help="Bind mount to add, repeatable. Combined with the newline-"
             "delimited $CAB_BIND_MOUNTS.",
    ),
) -> None:
    """cab: claude agent box, a named Claude Code container.

    Run `cab NAME` to launch the Claude agents UI in a container named
    NAME, building the image and creating the container on first use.
    `cab NAME` is shorthand for `cab agents NAME`; the other subcommands
    manage existing containers.
    """
    if ctx.invoked_subcommand is None:
        console.print("Specify a proejct name, for example [bold]cab myproject[/].")
        console.print("[dim]Run [bold]cab --help[/] for all commands.[/]")
        raise typer.Exit(1)
    require_docker()
    ctx.obj = mount or []


@app.command()
def agents(
    ctx: typer.Context,
    name: str = typer.Argument(..., help="Container name."),
) -> None:
    """Launch the Claude agents UI in the container (the default action)."""
    enter(name, ["claude", "agents"], ctx.obj)


@app.command()
def shell(
    ctx: typer.Context,
    name: str = typer.Argument(..., help="Container name."),
) -> None:
    """Exec a shell in the container."""
    enter(name, ["bash"], ctx.obj)


@app.command()
def build() -> None:
    """Rebuild the image. Existing containers pick it up when recreated."""
    ensure_image(force_build=True)


@app.command()
def stop(
    name: str = typer.Argument(..., help="Container name."),
) -> None:
    """Stop the container."""
    container = container_name(name)
    if quiet_ok("docker", "container", "inspect", container):
        run("docker", "stop", container, stdout=subprocess.DEVNULL)
        console.print(f"Stopped [cyan]{container}[/].")
    else:
        console.print(f"No such container: [cyan]{container}[/]", style="dim")


@app.command()
def kill(
    name: str = typer.Argument(..., help="Container name."),
    force: bool = typer.Option(
        False, "--force", "-f", help="Skip confirmation prompts.",
    ),
    purge: bool = typer.Option(
        False, "--purge",
        help="Also remove the named volume holding the container's Claude config.",
    ),
) -> None:
    """Remove the container. Its named volume is left intact unless --purge."""
    container = container_name(name)
    vol = volume_name(name)
    container_exists = quiet_ok("docker", "container", "inspect", container)
    volume_exists = quiet_ok("docker", "volume", "inspect", vol)
    if not container_exists and not volume_exists:
        console.print(f"Nothing to remove for [cyan]{name}[/].", style="dim")
        return

    running = container_exists and is_running(container)
    if running and not force:
        if not Confirm.ask(
            f"Delete container [cyan]{container}[/]? "
            "[yellow]This ends any active session.[/]",
            default=True,
        ):
            raise typer.Abort()

    if container_exists:
        run("docker", "rm", "-f", container, stdout=subprocess.DEVNULL)
        console.print(f"  Removed container [cyan]{container}[/].")

    # The volume holds the saved Claude config, so it is kept by default.
    # --purge removes it outright; otherwise ask, unless --force.
    remove_volume = volume_exists and (
        purge or (not force and Confirm.ask(
            f"Delete volume [cyan]{vol}[/]? "
            "[yellow]This is the saved Claude config.[/]",
            default=False,
        ))
    )
    if remove_volume:
        run("docker", "volume", "rm", vol, stdout=subprocess.DEVNULL)
        console.print(f"  Removed volume [cyan]{vol}[/].")
    elif volume_exists:
        console.print(f"  [dim]Volume [cyan]{vol}[/] kept.[/]")


@app.command("list")
def list_() -> None:
    """List all cab containers and volumes, including orphans."""
    containers = subprocess.run(
        ["docker", "ps", "-a", "--filter", f"label={DOCKER_LABEL}",
         "--format", "{{.Names}}\t{{.State}}"],
        capture_output=True, text=True, check=True,
    ).stdout.splitlines()
    volumes = subprocess.run(
        ["docker", "volume", "ls", "--filter", f"label={DOCKER_LABEL}",
         "--format", "{{.Name}}"],
        capture_output=True, text=True, check=True,
    ).stdout.splitlines()

    # Join containers and volumes by name so an orphaned volume (one with
    # no container) shows up as its own row.
    rows: dict[str, dict] = {}
    for line in containers:
        cname, _, state = line.partition("\t")
        name = cname.removeprefix(f"{PREFIX}-")
        rows.setdefault(name, {}).update(container=cname, state=state)
    for vname in volumes:
        name = vname.removeprefix(f"{PREFIX}-").removesuffix("-claude")
        rows.setdefault(name, {})["volume"] = True

    if not rows:
        console.print("No cab containers or volumes.", style="dim")
        return

    table = Table()
    table.add_column("Name")
    table.add_column("State")
    table.add_column("Volume")
    for name in sorted(rows):
        row = rows[name]
        state = row.get("state", "—")
        orphan = "container" not in row
        table.add_row(
            name,
            f"[green]{state}[/]" if state == "running" else state,
            "yes" if row.get("volume") else "—",
            style="yellow" if orphan else None,
        )
    console.print(table)


if __name__ == "__main__":
    app()
